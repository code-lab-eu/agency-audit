# Agency Audit environment configuration
#
# Copy to .env and adjust for your deployment. Every variable is read by
# src/agency_audit/config.py (pydantic-settings) using the AGENCY_AUDIT_
# prefix. Commented-out lines show the built-in default; uncomment to
# override.

# -- PostgreSQL connection -------------------------------------------------

# Hostname of the PostgreSQL server.
AGENCY_AUDIT_PG_HOST=localhost
# TCP port the PostgreSQL server listens on.
AGENCY_AUDIT_PG_PORT=5432
# Role used to authenticate to PostgreSQL.
AGENCY_AUDIT_PG_USER=agency_audit
# Password for the role above. Leave empty for password-less local auth;
# set it in any shared or production deployment.
AGENCY_AUDIT_PG_PASSWORD=agency_audit
# Name of the database to connect to.
AGENCY_AUDIT_PG_DATABASE=agency_audit

# -- PostgreSQL pool tuning (optional) -------------------------------------

# Minimum number of connections the asyncpg pool keeps open at all times.
# AGENCY_AUDIT_PG_POOL_MIN_SIZE=2
# Maximum number of connections the asyncpg pool may open.
# AGENCY_AUDIT_PG_POOL_MAX_SIZE=10
# Seconds a single SQL command may run before it is aborted.
# AGENCY_AUDIT_PG_POOL_COMMAND_TIMEOUT=30

# -- Geonames import settings ----------------------------------------------

# Minimum city population threshold; cities below this are skipped on import.
AGENCY_AUDIT_GEONAMES_MIN_POPULATION=50000
# URL of the Geonames dump archive to download and import.
# AGENCY_AUDIT_GEONAMES_URL=https://download.geonames.org/export/dump/cities15000.zip
# Seconds to wait for the Geonames archive download before giving up.
# AGENCY_AUDIT_GEONAMES_DOWNLOAD_TIMEOUT=120

# -- Google Maps Places API ------------------------------------------------

# API key for the Google Maps Places API, required by `agency-audit discover`.
# Discovery exits with an error if this key is not set. Create one at:
#   https://console.cloud.google.com/apis/credentials
AGENCY_AUDIT_GOOGLE_MAPS_API_KEY=

# Places tiling / discovery knobs
# How many layers of recursive quadtree subdivision before giving up
AGENCY_AUDIT_PLACES_TILE_MAX_DEPTH=3
# Minimum result count in a tile to consider it "saturated" (stop subdividing)
AGENCY_AUDIT_PLACES_TILE_SATURATION_THRESHOLD=60
# Hard cap on Places API calls per city during tiled discovery
AGENCY_AUDIT_PLACES_MAX_CALLS_PER_CITY=200
# Fallback bounding-box half-extent in metres (used when city boundaries unknown)
AGENCY_AUDIT_PLACES_CITY_HALF_EXTENT_METERS=15000

# Seconds to wait for each Places API request before timing out.
# AGENCY_AUDIT_PLACES_API_TIMEOUT=30
# Search radius, in metres, used when querying the Places API.
# AGENCY_AUDIT_PLACES_RADIUS_METERS=10000
# Maximum number of places returned per discovery search.
# AGENCY_AUDIT_PLACES_MAX_RESULTS=60
# Client-side rate limit, in queries per second, for Places API calls.
# AGENCY_AUDIT_PLACES_RATE_LIMIT_QPS=5.0

# -- Audit HTTP defaults (optional) ----------------------------------------

# User-Agent header sent on all audit HTTP requests (and robots.txt checks).
# AGENCY_AUDIT_USER_AGENT=AgencyAuditBot/1.0
# Seconds to wait when fetching a site's main page during an audit.
# AGENCY_AUDIT_AUDIT_TIMEOUT=30
# Seconds to wait when fetching robots.txt.
# AGENCY_AUDIT_ROBOTS_TIMEOUT=10
# Seconds to wait for individual HTTP requests made by audit sub-checks
# (tech stack, listing quality, API detection, property count, etc.).
# AGENCY_AUDIT_AUDIT_HTTP_TIMEOUT=15
# Seconds to wait when fetching a site's sitemap.xml.
# AGENCY_AUDIT_SITEMAP_TIMEOUT=20
# Seconds to wait for the TCP connection to a host to be established.
# AGENCY_AUDIT_SOCKET_CONNECT_TIMEOUT=10
# Number of sites audited concurrently in a batch run.
# AGENCY_AUDIT_AUDIT_CONCURRENCY=5

# -- Playwright browser fetcher (optional) ---------------------------------

# Page-load timeout, in milliseconds, for the Playwright-based fetcher.
# AGENCY_AUDIT_PLAYWRIGHT_TIMEOUT_MS=30000
# Extra seconds to wait after load to let client-side JS settle.
# AGENCY_AUDIT_PLAYWRIGHT_WAIT_SECONDS=3.0

# -- Web dashboard server (optional) ---------------------------------------
# Interface the `agency-audit serve` dashboard binds to.
# AGENCY_AUDIT_SERVE_HOST=127.0.0.1
# Port the `agency-audit serve` dashboard listens on.
# AGENCY_AUDIT_SERVE_PORT=8000

# -- Scoring config (optional) ---------------------------------------------

# Explicit path to a custom scoring_config.yaml. Leave empty to let the
# scorer auto-discover the bundled default.
# AGENCY_AUDIT_SCORING_CONFIG_PATH=

# -- Logging (optional) ----------------------------------------------------

# Minimum log severity to emit (DEBUG, INFO, WARNING, ERROR, CRITICAL).
# AGENCY_AUDIT_LOG_LEVEL=INFO
# Log output format: "json" for structured logs, "console" for human-readable.
# AGENCY_AUDIT_LOG_FORMAT=json
