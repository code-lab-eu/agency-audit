# Agency Audit environment configuration
# Copy to .env and adjust for your deployment.

# -- PostgreSQL connection -------------------------------------------------
AGENCY_AUDIT_PG_HOST=localhost
AGENCY_AUDIT_PG_PORT=5432
AGENCY_AUDIT_PG_USER=agency_audit
AGENCY_AUDIT_PG_PASSWORD=

# -- Docker Compose credentials ---------------------------------------------
# When running via docker compose, the Postgres container and app service
# use these variables (loaded by docker-compose, not the Python app).
# Override them to use custom credentials instead of the defaults below.
# POSTGRES_USER=agency_audit
# POSTGRES_PASSWORD=agency_audit
# POSTGRES_DB=agency_audit

# -- PostgreSQL pool tuning (optional) -------------------------------------
# AGENCY_AUDIT_PG_POOL_MIN_SIZE=2
# AGENCY_AUDIT_PG_POOL_MAX_SIZE=10
# AGENCY_AUDIT_PG_POOL_COMMAND_TIMEOUT=30

# -- Geonames import settings ----------------------------------------------
AGENCY_AUDIT_GEONAMES_MIN_POPULATION=50000
# AGENCY_AUDIT_GEONAMES_URL=https://download.geonames.org/export/dump/cities15000.zip
# AGENCY_AUDIT_GEONAMES_DOWNLOAD_TIMEOUT=120

# -- Google Maps Places API ------------------------------------------------
# Required for `agency-audit discover`. Get one at:
#   https://console.cloud.google.com/apis/credentials
AGENCY_AUDIT_GOOGLE_MAPS_API_KEY=
# AGENCY_AUDIT_PLACES_API_TIMEOUT=
# AGENCY_AUDIT_PLACES_RADIUS_METERS=10000
# AGENCY_AUDIT_PLACES_MAX_RESULTS=60
# AGENCY_AUDIT_PLACES_RATE_LIMIT_QPS=5.0

# -- Audit HTTP defaults (optional) ----------------------------------------
# AGENCY_AUDIT_USER_AGENT=AgencyAuditBot/1.0
# AGENCY_AUDIT_AUDIT_TIMEOUT=30
# AGENCY_AUDIT_ROBOTS_TIMEOUT=10
# AGENCY_AUDIT_AUDIT_HTTP_TIMEOUT=15
# AGENCY_AUDIT_SITEMAP_TIMEOUT=20
# AGENCY_AUDIT_SOCKET_CONNECT_TIMEOUT=10
# AGENCY_AUDIT_AUDIT_CONCURRENCY=5

# -- Playwright browser fetcher (optional) ---------------------------------
# AGENCY_AUDIT_PLAYWRIGHT_TIMEOUT_MS=30000
# AGENCY_AUDIT_PLAYWRIGHT_WAIT_SECONDS=3.0

# -- Web dashboard server (optional) ---------------------------------------
# AGENCY_AUDIT_SERVE_HOST=127.0.0.1
# AGENCY_AUDIT_SERVE_PORT=8000

# -- Scoring config (optional) ----------------------------------------------
# Path to a custom scoring_config.yaml file (default: auto-discovered)
# AGENCY_AUDIT_SCORING_CONFIG_PATH=
