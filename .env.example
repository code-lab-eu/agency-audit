# Agency Audit environment configuration
AGENCY_AUDIT_PG_HOST=localhost
AGENCY_AUDIT_PG_PORT=5432
AGENCY_AUDIT_PG_USER=agency_audit
AGENCY_AUDIT_PG_PASSWORD=agency_audit
AGENCY_AUDIT_PG_DATABASE=agency_audit
# Geonames import settings
AGENCY_AUDIT_GEONAMES_MIN_POPULATION=50000
# Google Maps Places API key, used by `agency-audit discover`.
# Discovery exits with an error if this key is not set.
AGENCY_AUDIT_GOOGLE_MAPS_API_KEY=
