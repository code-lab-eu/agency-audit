# Agency Audit environment configuration
AGENCY_AUDIT_PG_HOST=localhost
AGENCY_AUDIT_PG_PORT=5432
AGENCY_AUDIT_PG_USER=agency_audit
AGENCY_AUDIT_PG_PASSWORD=
AGENCY_AUDIT_PG_DATABASE=agency_audit
# Geonames import settings
AGENCY_AUDIT_GEONAMES_MIN_POPULATION=50000
# Google Maps Places API key, used by `agency-audit discover`.
# If unset, discovery falls back to browser-based Google Maps scraping.
AGENCY_AUDIT_GOOGLE_MAPS_API_KEY=

# Places tiling / discovery knobs
# How many layers of recursive quadtree subdivision before giving up
AGENCY_AUDIT_PLACES_TILE_MAX_DEPTH=3
# Minimum result count in a tile to consider it "saturated" (stop subdividing)
AGENCY_AUDIT_PLACES_TILE_SATURATION_THRESHOLD=60
# Hard cap on Places API calls per city during tiled discovery
AGENCY_AUDIT_PLACES_MAX_CALLS_PER_CITY=200
# Fallback bounding-box half-extent in metres (used when city boundaries unknown)
AGENCY_AUDIT_PLACES_CITY_HALF_EXTENT_METERS=15000
